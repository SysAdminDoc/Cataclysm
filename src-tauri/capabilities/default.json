{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set: core window/event controls, persistent settings store, and shell-open restricted to vetted citation/settings URLs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-delete",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://cesium.com/ion/signup" },
        { "url": "https://www.naturalearthdata.com/about/terms-of-use/" },
        { "url": "https://operations.osmfoundation.org/policies/tiles/" },
        { "url": "https://www.openstreetmap.org/copyright" },
        { "url": "https://www.esri.com/en-us/legal/terms/full-master-agreement" },
        { "url": "https://developers.arcgis.com/documentation/mapping-apis-and-services/deployment/attribution/" },
        { "url": "https://cesium.com/legal/terms-of-service/" },
        { "url": "https://cesium.com/legal/credits/" },
        { "url": "https://www.apache.org/licenses/LICENSE-2.0" },
        { "url": "https://doi.org/10.1029/2021AV000627" },
        { "url": "https://www.nature.com/articles/37044" },
        { "url": "https://agupubs.onlinelibrary.wiley.com/doi/10.1029/2011GL049210" },
        { "url": "https://www.science.org/doi/10.1126/science.1112250" },
        { "url": "https://agupubs.onlinelibrary.wiley.com/doi/10.1029/2018JC014893" },
        { "url": "https://www.science.org/doi/10.1126/science.abo4364" },
        { "url": "https://agupubs.onlinelibrary.wiley.com/doi/10.1029/2001GL013110" },
        { "url": "https://www.forbes.com/sites/davidhambling/2022/05/04/russias-poseidon-2km-tsunami-apocalypse-weapon-just-propaganda/" },
        { "url": "http://library.lanl.gov/tsunami/ts193.pdf" },
        { "url": "http://www.tsunamisociety.org/213choi.pdf" }
      ]
    }
  ]
}
