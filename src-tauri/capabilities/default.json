{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set: core window/event controls, persistent settings store, and shell-open restricted to peer-reviewed citation publishers.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-has",
    "store:allow-keys",
    "store:allow-entries",
    "store:allow-clear",
    "store:allow-delete",
    "store:allow-reload",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://*.cesium.com" },
        { "url": "https://cesium.com/*" },
        { "url": "https://doi.org/*" },
        { "url": "https://agupubs.onlinelibrary.wiley.com/*" },
        { "url": "https://www.science.org/*" },
        { "url": "https://www.nature.com/*" },
        { "url": "https://www.researchgate.net/*" },
        { "url": "https://www.sciencedirect.com/*" },
        { "url": "https://www.forbes.com/*" },
        { "url": "http://www.tsunamisociety.org/*" },
        { "url": "http://library.lanl.gov/*" },
        { "url": "https://nuclearsecrecy.com/*" },
        { "url": "https://impact.ese.ic.ac.uk/*" },
        { "url": "https://www.ndbc.noaa.gov/*" },
        { "url": "https://nctr.pmel.noaa.gov/*" },
        { "url": "https://www.gebco.net/*" },
        { "url": "https://www.ncei.noaa.gov/*" },
        { "url": "https://portal.opentopography.org/*" },
        { "url": "https://www.naturalearthdata.com/*" },
        { "url": "https://www.clawpack.org/*" },
        { "url": "https://github.com/SysAdminDoc/TsunamiSimulator*" }
      ]
    }
  ]
}
