    "description": "Abbreviated DART (Deep-ocean Assessment and Reporting of Tsunamis) buoy historical observations for three modern events. Time series are downsampled to ~5-minute resolution from the NOAA NCEI tsunami event archive (raw is 15-second event-mode + 15-minute standard-mode). Used to overlay observed vs. simulated water-surface elevation in the app's DartOverlay component.",
    "sources": [
      "NOAA NDBC DART event archive: https://www.ndbc.noaa.gov/dart/",
      "NCEI Tsunami Event Database: https://www.ngdc.noaa.gov/hazel/view/hazards/tsunami/",
      "PMEL Tsunami Research: https://nctr.pmel.noaa.gov/"
    ],
    "schema": {
      "buoys[].id": "integer NDBC station number",
      "buoys[].lat / lon": "deg WGS84",
      "buoys[].depth_m": "deployed depth, m",
      "buoys[].observations[]": "[t_s_since_event, eta_m] samples"
    }
  },
